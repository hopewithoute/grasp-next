{
  "name": "@grasp/web",
  "private": true,
  "scripts": {
    "build": "next build --turbopack",
    "dev": "next dev --turbopack",
    "eval:agents": "pnpm eval:refinement && pnpm eval:ingestion",
    "eval:ingestion": "tsx evals/mastra/ingestion.eval.ts",
    "eval:refinement": "tsx evals/mastra/refinement.eval.ts",
    "lint": "eslint . --max-warnings=0",
    "test": "node --env-file=../../.env ./node_modules/.bin/vitest run",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@grasp/ai": "workspace:*",
    "@grasp/db": "workspace:*",
    "@grasp/domain": "workspace:*",
    "@tailwindcss/postcss": "^4.3.0",
    "@xyflow/react": "^12.10.2",
    "ai": "^6.0.190",
    "better-auth": "^1.6.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.14.0",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "tsx": "^4.21.0",
    "vitest": "^3.2.4"
