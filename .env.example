# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/grasp

# Better Auth
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=http://localhost:3000

# AI Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Mastra
MASTRA_STORAGE_URL=postgres://postgres:postgres@localhost:5432/grasp
MASTRA_TELEMETRY_DISABLED=false

# Queue
QUEUE_REDIS_URL=redis://localhost:6379
QUEUE_PREFIX=grasp
