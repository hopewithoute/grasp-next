# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/grasp_web

# Better Auth
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI Providers
AI_MODEL=xiaomi/mimo-v2.5-pro
XIAOMI_API_KEY=
XIAOMI_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_API_KEY=

# LazyGraphRAG local runtimes
LGS_ENABLED=true
LEGACY_KNOWLEDGEBASE_READS_ENABLED=false
LGS_BASE_URL=http://127.0.0.1:8000
LGS_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/grasp_lgs
LGS_API_KEY=local-dev-key
LGS_CHUNK_TARGET_TOKENS=512
LGS_CHUNK_OVERLAP_TOKENS=64
LGS_CHUNK_MIN_TOKENS=80
TERM_EXTRACTOR_BASE_URL=http://127.0.0.1:8765
TERM_EXTRACTOR_API_KEY=local-dev-key
TERM_EXTRACTOR_THRESHOLD=0.5
TERM_EXTRACTOR_LABELS=concept,topic,technology,tool,framework,method,process,principle,metric,organization,person,location
GLINER_MODEL=.models/gliner_multi-v2.1
GLINER_THRESHOLD=0.5

EMBEDDING_BASE_URL=http://127.0.0.1:8766/v1
EMBEDDING_API_KEY=local-dev-key
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_MODEL_PATH=.models/qwen3-embedding-0.6b-gguf/Qwen3-Embedding-0.6B-Q8_0.gguf
EMBEDDING_DIMENSIONS=1024
EMBEDDING_DISTANCE=cosine
EMBEDDING_STORAGE=halfvec
EMBEDDING_CONTEXT_SIZE=8192
EMBEDDING_THREADS=

# Mastra
MASTRA_STORAGE_URL=postgres://postgres:postgres@localhost:5432/grasp_mastra
MASTRA_TELEMETRY_DISABLED=false

# Queue
QUEUE_REDIS_URL=redis://localhost:6379
QUEUE_PREFIX=grasp
CLOUDFLARE_ACCOUNT_ID="masukkan_id_akun_cloudflare_anda_disini"
CLOUDFLARE_API_TOKEN="masukkan_token_api_browser_rendering_disini"
