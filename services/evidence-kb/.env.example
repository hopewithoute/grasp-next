# Evidence KB Service Configuration

# Authentication
API_KEY=

# Database (Postgres with pgvector)
DATABASE_URL=postgresql://postgres:gas12kilo@localhost:5432/evidence_kb
DB_SCHEMA=evidence_kb

# Storage backend: "memory" (dev/test) or "postgres" (production)
STORAGE_BACKEND=memory

# Embedding sidecar (OpenAI-compatible)
EMBEDDING_SERVICE_URL=http://localhost:8001/v1/embeddings
EMBEDDING_SERVICE_API_KEY=
EMBEDDING_DIMENSIONS=1536

# Chunking
CHUNK_SIZE_CHARS=1200
CHUNK_OVERLAP_CHARS=160

# Retrieval
RRF_K=60
DEFAULT_TOP_K=12
